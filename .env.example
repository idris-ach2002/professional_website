POSTGRES_DB=idrisdatabase
POSTGRES_USER=ai222829
POSTGRES_PASSWORD=change_me

PORTFOLIO_ADMIN_USERNAME=admin
PORTFOLIO_ADMIN_PASSWORD=change_me

# Local front URL. In production, set both to the exact Cloudflare origin.
APP_CORS_ALLOWED_ORIGIN=http://localhost:5173
APP_FRONTEND_ORIGIN=http://localhost:5173

JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
HIBERNATE_FORMAT_SQL=true
HIBERNATE_HIGHLIGHT_SQL=true

UPLOAD_DIR=/app/uploads

# local | cloudinary
STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=portfolio

# CV Builder LaTeX
# En production Docker/Render, le Dockerfile installe latexmk + TeX Live.
CV_LATEX_COMPILER=latexmk
CV_LATEX_TIMEOUT_SECONDS=45
CV_STORE_LATEX_SOURCE=true
